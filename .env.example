# ==========================================
# 声浪雷达 LLM 配置 (.env)
# ==========================================
# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略。
#
# 报告生成模块使用 OpenAI 兼容协议（/v1/chat/completions）。
# 以下提供商均可，按需选一个：

# ---- DeepSeek（默认，便宜、国内可直连）----
# 申请：https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-your-deepseek-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ---- 智谱 GLM（推荐，国内可直连，有免费额度）----
# 申请：https://open.bigmodel.cn/apikey
# LLM_API_KEY=your-zhipu-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# ---- 通义千问 Qwen（阿里云）----
# LLM_API_KEY=sk-your-dashscope-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo

# ---- OpenAI（需代理）----
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ---- 本地 Ollama（零 API 成本，需先 ollama pull qwen2.5:7b）----
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b

# 调用超时（秒）
LLM_TIMEOUT=30

# ==========================================
# Webhook 告警配置（可选）
# ==========================================
# 当监测任务检测到 high 风险等级时自动推送告警。
# 不配置则不告警。通过 URL 自动识别平台。
#
# --- 飞书机器人 ---
# 申请：https://open.feishu.cn/document/ukTMukTMukTM/ucTM5YjL3ETO24yNxkjN# 创建自定义机器人
# ALERT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
#
# --- 钉钉机器人 ---
# 申请：https://open.dingtalk.com/document/robots/custom-robot-access 设置"安全设置"→"加签"
# ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx
#
# --- 企业微信机器人 ---
# 申请：https://work.weixin.qq.com/api/doc/90000/90136/91770
# ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

ALERT_WEBHOOK_URL=
# 触发告警的最低风险等级：low / medium / high（默认 high）
ALERT_MIN_RISK=high
# 同一任务的告警冷却时间（秒），默认 3600（1 小时）
ALERT_COOLDOWN_SEC=3600

# ==========================================
# 小红书 Cookie 配置（可选）
# ==========================================
# 小红书功能需要登录后的 Cookie。有两种配置方式：
#
# 方式1（推荐，适合 Railway 等云平台）：设置 XHS_COOKIES 整体变量
# 格式与 HTTP Cookie 头一致，分号分隔：
# XHS_COOKIES=a1=xxx; web_session=xxx; webId=xxx; xsecappid=xhs-pc-web; abRequestId=xxx; acw_tc=xxx
#
# 方式2：单独设置各字段（会覆盖 XHS_COOKIES 中的同名字段）
# XHS_A1=xxx
# XHS_WEB_SESSION=xxx
# XHS_WEB_ID=xxx
# XHS_XSECAPPID=xhs-pc-web
# XHS_AB_REQUEST_ID=xxx
# XHS_ACW_TC=xxx
#
# 方式3（仅本地）：在项目根目录创建 cookies_xhs.txt，每行一个 key=value
#
# 获取方式：浏览器登录小红书 → F12 开发者工具 → Application → Cookies
# 复制 a1 和 web_session 字段的值即可。

XHS_COOKIES=
XHS_A1=
XHS_WEB_SESSION=
XHS_WEB_ID=
